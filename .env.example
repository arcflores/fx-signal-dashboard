# ─────────────────────────────────────────────────────────────
# Variables de entorno — copiar como .env y completar valores
# NUNCA subir el archivo .env real a GitHub
# ─────────────────────────────────────────────────────────────

# API Key de Anthropic (Claude AI) — obtener en console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api...

# API Key de OANDA — obtener en developers.oanda.com (cuenta live o practice)
OANDA_API_KEY=
OANDA_ACCOUNT_ID=

# Ambiente de OANDA: "practice" (demo) o "trade" (real)
OANDA_ENV=practice
